{
  "author": "Jonas Thelemann",
  "description": "DJ cReal's website.",
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1042.0",
    "@aws-sdk/s3-request-presigner": "3.1042.0",
    "@dargmuesli/nuxt-cookie-control": "9.1.22",
    "@dargmuesli/nuxt-vio": "21.0.5",
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "6.0.0",
    "@graphql-codegen/typescript-urql-graphcache": "4.0.2",
    "@graphql-codegen/urql-introspection": "4.0.1",
    "@graphql-typed-document-node/core": "3.2.0",
    "@headlessui/vue": "1.7.23",
    "@heroicons/vue": "2.2.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/scripts": "1.0.6",
    "@pinia/nuxt": "0.11.3",
    "@skjnldsv/vue-plyr": "7.5.0",
    "@takumi-rs/core": "1.1.2",
    "@types/html-to-text": "9.0.4",
    "@types/lodash-es": "4.17.12",
    "@urql/core": "6.0.1",
    "@urql/devtools": "2.0.3",
    "@urql/exchange-graphcache": "9.0.0",
    "@urql/vue": "2.1.0",
    "@vuelidate/core": "2.0.3",
    "@vuelidate/validators": "2.0.4",
    "clsx": "2.1.1",
    "consola": "3.4.2",
    "defu": "6.1.7",
    "eslint": "10.3.0",
    "graphql": "16.13.2",
    "h3": "1.15.11",
    "html-to-text": "10.0.0",
    "lodash-es": "4.18.1",
    "marked": "18.0.3",
    "nuxt": "4.4.4",
    "nuxt-security": "2.5.1",
    "pinia": "3.0.4",
    "plyr": "3.8.4",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "pretty-bytes": "7.1.0",
    "serve": "14.2.6",
    "sharp": "0.34.5",
    "stylelint": "17.11.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "ufo": "1.6.4",
    "vue": "3.5.33",
    "vue-router": "5.0.6",
    "vue-tsc": "3.2.8"
  },
  "engines": {
    "node": "24"
  },
  "name": "creal",
  "private": true,
  "scripts": {
    "build": "pnpm run build:node",
    "build:node": "nuxt build",
    "build:static": "nuxt generate",
    "build:static:test": "NUXT_PUBLIC_VIO_IS_TESTING=true pnpm run build:static",
    "certificates": ".config/certificates/mkcert.sh",
    "dev": "pnpm run start:dev",
    "generate": "pnpm run build:static",
    "gql:codegen": "NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" graphql-codegen --config .config/codegen/.rc.dev.ts",
    "gql:codegen:prod": "graphql-codegen --config .config/codegen/.rc.prod.ts",
    "lint": "pnpm run lint:js && pnpm run lint:ts && pnpm run lint:style",
    "lint:fix": "pnpm run lint:js --fix && pnpm run lint:ts --fix && pnpm run lint:style --fix",
    "lint:js": "eslint --cache",
    "lint:style": "stylelint --cache \"**/*.{vue,css}\" --ignore-path .gitignore",
    "lint:ts": "nuxt typecheck",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "start": "pnpm run start:node",
    "start:dev": "pnpm run certificates && NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" nuxt dev",
    "start:node": "node node/server/node.mjs",
    "start:static": "node node/server/static.mjs"
  },
  "type": "module",
  "version": "5.3.3"
}
